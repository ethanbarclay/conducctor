FROM node:22-slim

# Install system dependencies (pgrep, curl needed by Gemini CLI)
RUN apt-get update -qq && apt-get install -y -qq procps curl && rm -rf /var/lib/apt/lists/*

# Install Gemini CLI
RUN npm install -g @google/gemini-cli

# Create workspace and home directory for non-root user
RUN mkdir -p /workspace /home/node/.gemini && chown -R node:node /home/node /workspace

WORKDIR /workspace

ENTRYPOINT ["gemini"]
