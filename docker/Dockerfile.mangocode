# MangoCode container image
#
# Fast build: copy pre-built binary from host
#   cp /usr/local/bin/mangocode docker/mangocode-bin
#   docker build -t conductor-mangocode:latest -f docker/Dockerfile.mangocode docker/
#
# Full build (from source, slow):
#   docker build -t conductor-mangocode:latest -f docker/Dockerfile.mangocode.full .

FROM debian:trixie-slim

RUN apt-get update -qq && apt-get install -y -qq ca-certificates curl git procps libasound2 && rm -rf /var/lib/apt/lists/*

# Copy pre-built binary (place mangocode-bin in docker/ before building)
COPY mangocode-bin /usr/local/bin/mangocode
RUN chmod +x /usr/local/bin/mangocode

RUN mkdir -p /workspace /home/node/.claude /home/node/.mangocode && \
    groupadd -r node && useradd -r -g node -m -d /home/node node && \
    chown -R node:node /home/node /workspace

WORKDIR /workspace

ENTRYPOINT ["mangocode"]
