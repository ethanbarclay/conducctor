# ── I-35 Spotter — Environment Variables ────────────────────────────────────
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ── Video Source ──────────────────────────────────────────────────────────────
# Production (Pi HQ Camera via mediamtx):
# VIDEO_SOURCE=rtsp://192.168.1.x:8554/cam

# Test mode (local video file — must be in TEST_VIDEO_DIR below):
# VIDEO_SOURCE=/data/test/my_footage.mov
# LOOP_VIDEO=true

# Leave blank to wait for Admin Panel start command:
VIDEO_SOURCE=

# Directory on host to mount as /data/test in detector container.
# Put your test .mov/.mp4 files here.
TEST_VIDEO_DIR=/path/to/your/test/videos

LOOP_VIDEO=false

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Frontend build URL ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Scoring ───────────────────────────────────────────────────────────────────
MIN_SCORE_TO_SAVE_CROP=6

# ── Dry run (no DB, prints to console) ───────────────────────────────────────
# DRY_RUN=true
